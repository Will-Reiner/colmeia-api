# Porta HTTP do servidor
PORT=3000

# Caminho do arquivo SQLite.
# Local: ./data/colmeia.db   |   Docker/Coolify: /app/data/colmeia.db
DB_PATH=/app/data/colmeia.db

# Ambiente (production | development)
NODE_ENV=production

